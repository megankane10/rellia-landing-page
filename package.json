{
  "name": "rellia",
  "private": true,
  "type": "module",
  "pkg": {
    "assets": [
      "dist/spa/*"
    ],
    "scripts": [
      "dist/server/**/*.js"
    ]
  },
  "scripts": {
    "dev": "vite",
    "build": "pnpm run build:client && pnpm run build:server && pnpm run build:api",
    "generate:seo-files": "tsx scripts/generate-sitemap-llms.ts",
    "build:client": "pnpm run generate:seo-files && pnpm run fetch:cms-snapshots && vite build",
    "fetch:cms-snapshots": "tsx scripts/fetch-cms-build-snapshots.ts",
    "build:api": "esbuild scripts/vercel-api-entry.ts --bundle --platform=node --target=node22 --format=esm --packages=external --external:dotenv --outfile=api/index.js",
    "build:server": "vite build --config vite.config.server.ts",
    "start": "node dist/server/node-build.mjs",
    "sanity:seed": "tsx scripts/sanity-seed.ts",
    "sanity:sync:investor-logos": "tsx scripts/sync-investor-logos.ts",
    "sanity:seed:settings": "tsx scripts/sanity-seed-settings.ts",
    "sanity:seed:starters": "tsx scripts/sanity-seed-starters.ts",
    "sanity:seed:story-filters": "tsx scripts/sanity-seed-story-filters.ts",
    "sanity:migrate:story-seo": "tsx scripts/sanity-migrate-story-seo.ts",
    "sanity:migrate:collection-seo": "tsx scripts/sanity-migrate-collection-seo.ts",
    "fix:story-slug": "tsx scripts/fix-story-slug.ts",
    "sanity:migrate:cms-headlines": "tsx scripts/sanity-migrate-cms-headlines.ts",
    "sanity:cleanup": "tsx scripts/sanity-cleanup.ts",
    "sanity:promote:dry": "tsx scripts/promote-preview-to-production.ts",
    "sanity:promote": "tsx scripts/promote-preview-to-production.ts",
    "sanity:sync-to-production:dry": "tsx scripts/sync-preview-to-production.ts",
    "sanity:sync-to-production": "tsx scripts/sync-preview-to-production.ts",
    "sanity:sync-to-preview:dry": "tsx scripts/sync-production-to-preview.ts",
    "sanity:sync-to-preview": "tsx scripts/sync-production-to-preview.ts",
    "sanity:sync-to-preview:preserve:dry": "tsx scripts/sync-production-to-preview.ts -- --preserve-placeholders",
    "sanity:sync-to-preview:preserve": "tsx scripts/sync-production-to-preview.ts -- --apply --preserve-placeholders",
    "sanity:delete-event": "tsx scripts/delete-sanity-event.ts",
    "sanity:studio:dev": "pnpm -C website-cms run dev",
    "sanity:studio:deploy": "pnpm -C website-cms run deploy",
    "sanity:deploy": "pnpm -C website-cms run deploy",
    "seed:advisors": "tsx scripts/seed-advisors.ts",
    "test": "vitest --run",
    "lint": "eslint .",
    "format.fix": "prettier --write .",
    "typecheck": "tsc"
  },
  "dependencies": {
    "@fillout/react": "^3.1.2",
    "@portabletext/react": "^6.0.3",
    "@sanity/client": "^7.22.0",
    "@sanity/image-url": "^2.1.0",
    "@sanity/preview-url-secret": "^4.0.6",
    "@sanity/visual-editing": "^4.0.3",
    "@stripe/react-stripe-js": "^6.4.0",
    "@stripe/stripe-js": "^9.5.0",
    "@supabase/supabase-js": "^2.105.4",
    "@vercel/analytics": "^2.0.1",
    "add-to-calendar-button-react": "^2.14.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.1",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "react-easy-crop": "^5.5.7",
    "react-helmet-async": "^3.0.0",
    "stripe": "^22.1.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@hookform/resolvers": "^5.2.1",
    "@radix-ui/react-accordion": "^1.2.11",
    "@radix-ui/react-alert-dialog": "^1.1.14",
    "@radix-ui/react-aspect-ratio": "^1.1.7",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-checkbox": "^1.3.2",
    "@radix-ui/react-collapsible": "^1.1.11",
    "@radix-ui/react-context-menu": "^2.2.15",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-hover-card": "^1.1.14",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-menubar": "^1.1.15",
    "@radix-ui/react-navigation-menu": "^1.2.13",
    "@radix-ui/react-popover": "^1.1.14",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-radio-group": "^1.3.7",
    "@radix-ui/react-scroll-area": "^1.2.9",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slider": "^1.3.5",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.5",
    "@radix-ui/react-tabs": "^1.1.12",
    "@radix-ui/react-toast": "^1.2.14",
    "@radix-ui/react-toggle": "^1.1.9",
    "@radix-ui/react-toggle-group": "^1.1.10",
    "@radix-ui/react-tooltip": "^1.2.7",
    "@swc/core": "^1.13.3",
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/react-query": "^5.84.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/node": "^24.2.1",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "@vitejs/plugin-react-swc": "^4.0.0",
    "autoprefixer": "^10.4.21",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "esbuild": "~0.25.8",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "framer-motion": "^12.23.12",
    "globals": "^16.3.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.539.0",
    "next-themes": "^0.4.6",
    "postcss": "^8.5.10",
    "prettier": "^3.6.2",
    "react": "^18.3.1",
    "react-day-picker": "^9.8.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.62.0",
    "react-resizable-panels": "^3.0.4",
    "react-router-dom": "^6.30.4",
    "recharts": "^2.12.7",
    "sonner": "^1.7.4",
    "tailwind-merge": "^2.6.0",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.20.3",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.60.1",
    "vaul": "^1.1.2",
    "vite": "^8.0.16",
    "vite-prerender-plugin": "^0.5.13",
    "vitest": "^4.1.0"
  },
  "packageManager": "pnpm@10.14.0+sha512.ad27a79641b49c3e481a16a805baa71817a04bbe06a38d17e60e2eaee83f6a146c6a688125f5792e48dd5ba30e7da52a5cda4c3992b9ccf333f9ce223af84748",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "@swc/core"
    ],
    "overrides": {
      "qs": ">=6.15.2",
      "body-parser": ">=2.2.2",
      "path-to-regexp@>=8.0.0": ">=8.4.2",
      "rollup": ">=4.59.0",
      "lodash": "^4.18.0",
      "minimatch": ">=9.0.7",
      "glob": ">=10.5.0",
      "picomatch": ">=4.0.4",
      "uuid": ">=11.1.1",
      "postcss": ">=8.5.10",
      "js-yaml@<3.14.2": ">=3.14.2",
      "js-yaml@>=4.0.0 <4.1.1": ">=4.1.1"
    }
  }
}
