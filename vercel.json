{
  "installCommand": "pnpm install",
  "buildCommand": "pnpm run build:client && pnpm run build:api",
  "outputDirectory": "dist/spa",
  "functions": {
    "api/index.js": {
      "maxDuration": 30
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors 'self' https://*.sanity.studio https://*.sanity.io"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/((?!assets/)(?!images/)(?!videos/)(?!_vercel/)(?!favicon\\.ico$)(?!ogimage\\.png$)(?!robots\\.txt$)(?!sitemap\\.xml$)(?!llms\\.txt$)(?!placeholder\\.svg$).*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/ogimage.png",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/health",
      "destination": "/api?__path=health"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api?__path=$1"
    },
    {
      "source": "/((?!api/)(?!_vercel/)(?!assets/)(?!images/)(?!videos/)(?!ogimage\\.png$)(?!favicon\\.ico$)(?!robots\\.txt$)(?!sitemap\\.xml$)(?!llms\\.txt$)(?!placeholder\\.svg$).*)",
      "destination": "/index.html"
    }
  ]
}
