{
  "cleanUrls": true,
  "trailingSlash": false,
  "installCommand": "pnpm install",
  "buildCommand": "pnpm run build:client && pnpm run build:api",
  "outputDirectory": "dist/spa",
  "functions": {
    "api/index.js": {
      "maxDuration": 30
    }
  },
  "redirects": [
    {
      "source": "/studio",
      "destination": "https://relliahealth.sanity.studio",
      "permanent": false
    },
    {
      "source": "/blog",
      "destination": "/stories",
      "permanent": true
    },
    {
      "source": "/diagnostics",
      "destination": "/startup-diagnostic",
      "permanent": true
    },
    {
      "source": "/survey",
      "destination": "/diagnostic-survey",
      "permanent": true
    },
    {
      "source": "/policy",
      "destination": "/privacy",
      "permanent": true
    },
    {
      "source": "/stories/website-launch",
      "destination": "/stories/a-clearer-path-for-digital-health-founders",
      "permanent": true
    },
    {
      "source": "/stories/welcome-to-the-new-rellia-website",
      "destination": "/stories/a-clearer-path-for-digital-health-founders",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors 'self' https://*.sanity.studio https://*.sanity.io"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/((?!assets/)(?!images/)(?!videos/)(?!_vercel/)(?!favicon\\.ico$)(?!robots\\.txt$)(?!sitemap\\.xml$)(?!llms\\.txt$)(?!placeholder\\.svg$).*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/images/opt/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/images/ogimage-:page.png",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/health",
      "destination": "/api?__path=health"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api?__path=$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index"
    }
  ]
}
