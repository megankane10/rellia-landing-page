# Optional: override Sanity project (defaults match website-cms/sanity.config.ts)
# VITE_SANITY_PROJECT_ID=
# VITE_SANITY_DATASET=production

# Contact form (file append + optional Resend email)
# CONTACT_SUBMISSIONS_PATH=
# RESEND_API_KEY=re_...
# CONTACT_TO_EMAIL=hello@relliahealth.com
# RESEND_FROM_EMAIL=Rellia Health <notifications@yourdomain.com>

# Gated /payment page — use URL /payment?key=<secret>. Server-only; do not use VITE_ prefix.
# PAYMENT_PAGE_SECRET=

# Stripe Embedded Checkout on /payment (same Price ID as the product behind your Payment Link)
# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PRICE_ID=price_...
