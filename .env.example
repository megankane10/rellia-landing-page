# Optional: override Sanity project (defaults match website-cms/sanity.config.ts)
# VITE_SANITY_PROJECT_ID=
# VITE_SANITY_DATASET=production

# Gated /payment page — share /payment?key=<same value>. Server-only (set in Vercel/Netlify too, not only .env).
# PAYMENT_PAGE_SECRET=

# Stripe Embedded Checkout on /payment (same Price ID as the product behind your Payment Link)
# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PRICE_ID=price_...
