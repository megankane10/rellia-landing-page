# =============================================================================
# Vercel PRODUCTION (relliahealth.com / www) — CMS enabled
# =============================================================================
# VITE_SITE_URL=https://www.relliahealth.com
# VITE_SANITY_PROJECT_ID=ggbt0o98
# VITE_SANITY_DATASET=production
# Do NOT set VITE_DISABLE_CMS on production (omit it entirely).
#
# Server (production dataset):
# SANITY_API_PROJECT_ID=ggbt0o98
# SANITY_API_DATASET=production
# SANITY_ENFORCE_VERCEL_DATASET=true
# SANITY_ALLOWED_DATASETS=preview,production
# SANITY_API_READ_TOKEN=...
# SANITY_STUDIO_URL=https://relliahealth.sanity.studio
#
# Lock cross-origin API use to your real sites (comma-separated):
# ALLOWED_ORIGINS=https://www.relliahealth.com,https://relliahealth.com

# =============================================================================
# Vercel PREVIEW / Additions branch (*.vercel.app) — preview dataset + drafts
# =============================================================================
# VITE_SITE_URL=https://relliahealth.vercel.app
# VITE_SANITY_PROJECT_ID=ggbt0o98
# VITE_SANITY_DATASET=preview
# Leave VITE_DISABLE_CMS unset
#
# SANITY_API_PROJECT_ID=ggbt0o98
# SANITY_API_DATASET=preview
# SANITY_ENFORCE_VERCEL_DATASET=true
# SANITY_ALLOWED_DATASETS=preview,production
# SANITY_API_READ_TOKEN=...
# SANITY_API_WRITE_TOKEN=...   # pnpm sanity:seed / pnpm sanity:cleanup
#
# ALLOWED_ORIGINS=https://relliahealth.vercel.app,https://www.relliahealth.com,https://relliahealth.com
#
# Studio Presentation iframe (preview deployment):
# SANITY_STUDIO_PREVIEW_URL=https://relliahealth.vercel.app

# =============================================================================
# Sanity Studio (local deploy or sanity.io)
# =============================================================================
# SANITY_STUDIO_PROJECT_ID=ggbt0o98
# SANITY_STUDIO_DATASET=preview
# SANITY_STUDIO_PREVIEW_URL=https://relliahealth.vercel.app
# Looker Studio embed (Analytics panel in Studio — no backend proxy)
# SANITY_STUDIO_LOOKER_EMBED_URL=https://lookerstudio.google.com/embed/reporting/.../page/...

# =============================================================================
# Sanity — anonymous GROQ (curl, scripts) to https://<projectId>.api.sanity.io/... cannot be blocked in this repo.
# CORS only affects browsers. **Private datasets** (token required for reads) need a paid Sanity plan — not on Free.
#
# Free-tier mitigations: treat the dataset like a public API — no secrets, PII, or embargoed copy. Your app already
# uses POST /api/sanity/query + a query whitelist + stripped responses (only your traffic).
# Growth+: set datasets to Private, then unauthenticated api.sanity.io queries return 401; keep SANITY_API_READ_TOKEN
# on the server only (never VITE_*).
#
# =============================================================================
# Sanity.io project — API CORS (browser). PowerShell/curl bypass CORS; use dataset design + tokens.
# In https://sanity.io/manage → Project → API → CORS origins, allow only:
#   - https://www.relliahealth.com
#   - https://relliahealth.com
#   - https://*.vercel.app (or your exact preview host)
#   - http://localhost:3333 (Studio dev) if needed
# Remove wildcard (*) origins.

# =============================================================================
# Other
# =============================================================================
# API hardening (this repo)
# -----------------------------------------------------------------------------
# Browser POSTs to /api/sanity/query, /api/contact, /api/stripe/checkout-session, /api/diagnostic-report require a CSRF token from
# GET /api/csrf-token (cookie + x-csrf-token header). Set REQUIRE_API_CSRF=false only for emergencies/tests.
# REQUIRE_API_CSRF=
#
# Direct queries to https://<projectId>.api.sanity.io/... are served by Sanity, not this app — public datasets
# stay readable without a token on the free plan. Rotating project id + empty sensitive content is operational;
# private datasets require a paid Sanity plan.
#
# Production Vercel: set SANITY_API_PROJECT_ID (or VITE_SANITY_PROJECT_ID). No baked-in project id fallback.

# Admin portal — SERVER env only (not VITE_). Set true only while inviting a new admin, then disable.
# Required on Vercel Production + Preview for /admin/signup. Also needs SUPABASE_SERVICE_ROLE_KEY.
# ADMIN_SIGNUP_ENABLED=true
#
# Supabase Auth (Dashboard → Authentication → URL configuration):
#   Site URL: https://www.relliahealth.com
#   Redirect URLs (add every line):
#     https://www.relliahealth.com/admin/auth/callback
#     https://www.relliahealth.com/admin/auth/callback**
#     https://www.relliahealth.com/accept-invite
#     https://www.relliahealth.com/accept-invite**
#     https://relliahealth.com/admin/auth/callback**
#     https://relliahealth.com/accept-invite**
#   Invite email redirect: https://www.relliahealth.com/accept-invite?confirmation_url={{ .ConfirmationURL }}
#   (Scanner-safe flow; user clicks Continue on /accept-invite before the token is consumed.)
#
# Supabase — contact form (`POST /api/contact` → `contact_responses` table). Run `scripts/supabase_setup.sql` once.
# Diagnostic survey (`POST /api/diagnostic-report` → `company_profiles` + `diagnostic_responses`). Run `scripts/supabase_diagnostic_setup.sql`.
# Slack — Supabase triggers (Vault: slack_webhook_url) + Sanity draft webhook (server env below)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...   # server only; same URL as Vault secret
# SANITY_SLACK_WEBHOOK_SECRET=...   # random string; append ?secret=... to Sanity webhook URL
# ADMIN_INBOX_PATH=/admin/submissions   # change to /admin/inbox when you rename the route
# VITE_ADMIN_INBOX_PATH=/admin/submissions   # optional client-side parity
#
# SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=...   # server only — never expose in VITE_*
# VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# VITE_SUPABASE_ANON_KEY=...   # contact form (browser insert via RLS); also SUPABASE_ANON_KEY on server
# VITE_SUPABASE_PUBLISHABLE_KEY=...   # legacy alias for anon key
#
# Stripe — membership checkout (`POST /api/stripe/checkout-session`, `/membership`)
# Embedded checkout (in-page) requires ALL of:
#   STRIPE_SECRET_KEY=sk_live_...              # server only
#   VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...
#   STRIPE_MONTHLY_PRICE_ID=price_...          # Stripe Dashboard → Products → Price ID
#   STRIPE_ANNUAL_PRICE_ID=price_...
# Register production domain under Stripe → Settings → Payment method domains.
# Payment links alone (redirect checkout) — set on server AND client (duplicate without VITE_ for API fallback):
# STRIPE_MONTHLY_PLAN_LINK=https://buy.stripe.com/...
# STRIPE_ANNUAL_PLAN_LINK=https://buy.stripe.com/...
# VITE_STRIPE_MONTHLY_PLAN_LINK=https://buy.stripe.com/...
# VITE_STRIPE_ANNUAL_PLAN_LINK=https://buy.stripe.com/...
#
# Optional — seed script (`pnpm run sanity:seed`): absolute URL for home `ctaImageUrl` when defaults use /images/...
# SEED_PUBLIC_SITE_ORIGIN=https://www.relliahealth.com
# QMS program enrollment (Fillout only — Secure your spot embeds this form, not Stripe)
# VITE_QMS_FILLOUT_FORM_URL=https://forms.fillout.com/t/1GPWpbBbWcus
